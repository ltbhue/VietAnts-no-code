generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  TESTER
  VIEWER
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  fullName  String
  role      Role     @default(TESTER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects    Project[]
  testScripts TestScript[] @relation("TestScriptCreatedBy")
  testRuns    TestRun[]
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects Project[]
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  ownerId     String
  workspaceId String?

  owner      User       @relation(fields: [ownerId], references: [id], onDelete: Restrict)
  workspace  Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  testScripts TestScript[]
  uiObjects   UiObject[]
  datasets    DataSet[]
  testCases   TestCase[]
  testSuites  TestSuite[]

  @@index([ownerId])
  @@index([workspaceId])
}

model TestScript {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  projectId   String
  createdById String

  project   Project @relation(fields: [projectId], references: [id], onDelete: Restrict)
  createdBy User    @relation("TestScriptCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  steps     TestStep[]
  runs      TestRun[]
}

model TestStep {
  id         String @id @default(cuid())
  order      Int
  keyword    String
  targetId   String?
  parameters Json?
  scriptId   String

  target UiObject?  @relation(fields: [targetId], references: [id], onDelete: SetNull)
  script TestScript @relation(fields: [scriptId], references: [id], onDelete: Restrict)
}

model UiObject {
  id          String   @id @default(cuid())
  name        String
  description String?
  locator     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  projectId   String

  project Project    @relation(fields: [projectId], references: [id], onDelete: Restrict)
  steps   TestStep[]
}

model DataSet {
  id          String @id @default(cuid())
  name        String
  description String?
  rows        Json
  projectId   String

  project Project   @relation(fields: [projectId], references: [id], onDelete: Restrict)
  runs    TestRun[]
}

model TestRun {
  id        String   @id @default(cuid())
  startedAt DateTime @default(now())
  finishedAt DateTime?
  status    String
  browser   String?
  scriptId  String
  userId    String
  dataSetId String?

  script  TestScript  @relation(fields: [scriptId], references: [id], onDelete: Restrict)
  user    User        @relation(fields: [userId], references: [id], onDelete: Restrict)
  dataSet DataSet?    @relation(fields: [dataSetId], references: [id], onDelete: SetNull)
  results TestResult[]
}

model TestResult {
  id         String   @id @default(cuid())
  stepOrder  Int
  status     String
  message    String?
  screenshot String?
  log        String?
  createdAt  DateTime @default(now())
  runId      String

  run TestRun @relation(fields: [runId], references: [id], onDelete: Restrict)
}

model TestCase {
  id          String   @id @default(cuid())
  title       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  versions TestCaseVersion[]

  @@index([projectId])
}

model TestCaseVersion {
  id        String   @id @default(cuid())
  version   Int
  content   Json
  createdAt DateTime @default(now())

  testCaseId String
  testCase   TestCase @relation(fields: [testCaseId], references: [id], onDelete: Cascade)

  suiteItems TestSuiteItem[]

  @@unique([testCaseId, version])
  @@index([testCaseId])
}

model TestSuite {
  id        String   @id @default(cuid())
  name      String
  projectId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  items   TestSuiteItem[]
  runs    SuiteRun[]

  @@index([projectId])
}

model TestSuiteItem {
  id                String @id @default(cuid())
  suiteId           String
  testCaseVersionId String
  sortOrder         Int    @default(0)

  suite   TestSuite       @relation(fields: [suiteId], references: [id], onDelete: Cascade)
  version TestCaseVersion @relation(fields: [testCaseVersionId], references: [id], onDelete: Restrict)

  @@unique([suiteId, testCaseVersionId])
  @@index([suiteId])
}

model SuiteRun {
  id          String    @id @default(cuid())
  suiteId     String
  status      String
  environment String?
  results     Json?
  startedAt   DateTime  @default(now())
  finishedAt  DateTime?
  trigger     String?
  buildId     String?
  commitSha   String?

  suite TestSuite @relation(fields: [suiteId], references: [id], onDelete: Cascade)

  @@index([suiteId])
}
